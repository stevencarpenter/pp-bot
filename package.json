{
  "name": "pp-bot",
  "version": "1.1.2",
  "description": "A Slack bot that manages a leaderboard of users with ++ and -- voting",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "npm run build && node dist/index.js",
    "migrate": "ts-node src/scripts/migrate.ts",
    "test": "node --no-warnings ./node_modules/jest/bin/jest.js",
    "test:coverage": "node --no-warnings ./node_modules/jest/bin/jest.js --coverage",
    "lint": "node -e \"console.log('Linting disabled by project configuration.');\"",
    "lint:fix": "node -e \"console.log('Linting disabled by project configuration.');\"",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "test:integration": "npm run build && npm run db:up && wait-on tcp:5433 && DATABASE_URL=postgres://ppbot:ppbot@localhost:5433/ppbot ts-node src/scripts/migrate.ts && DATABASE_URL=postgres://ppbot:ppbot@localhost:5433/ppbot node --no-warnings ./node_modules/jest/bin/jest.js src/__tests__/db.integration.test.ts --runInBand && npm run db:down",
    "ci": "npm ci && npm run build && npm test",
    "lock:regen": "rm -f package-lock.json && npm install --package-lock-only"
  },
  "keywords": [
    "slack",
    "bot",
    "leaderboard"
  ],
  "author": "Steven Carpenter",
  "license": "MIT",
  "dependencies": {
    "@slack/bolt": "^4.7.0",
    "axios": "^1.15.0",
    "pg": "^8.18.0",
    "validator": "^13.15.35"
  },
  "overrides": {
    "test-exclude": "^7.0.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.16.0",
    "@types/validator": "^13.15.10",
    "jest": "^30.2.0",
    "pg-mem": "^3.0.12",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.4"
  }
}
